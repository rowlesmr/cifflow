/* IUCr JavaScript tweaks to web page content */

/* Impose style on instances of string "IUCr" in certain contexts */

$(":header, nav").each(function(){
 var iucr_text = $(this).html().replace(/IUCr/g, '<span class="iucrlogo">IUCr</span>');
 $(this).html(iucr_text);
});
$("nav li>a").each(function(){
 var iucr_text = $(this).html().replace(/iucr/g, '<span class="iucrlogo">IUCr</span>');
 iucr_text = $(this).html().replace(/<span class="<span class="iucrlogo"IUCr<\/span>"logo">/g, '<span class="iucrlogo">IUCr>');
 $(this).html(iucr_text);
});
$("a.heading").each(function(){
 var iucr_text = $(this).html().replace(/IUCr/g, '<span class="iucrlogo">IUCr</span>');
 $(this).html(iucr_text);
});
$("nav li>a").each(function(){
 var iucr_text = $(this).html().replace(/iycr2014/g, '<span class="iucrlogo">IYCr2014</span>');
 $(this).html(iucr_text);
});
$("a.btn").each(function(){
 var iucr_text = $(this).html().replace(/IUCr/g, '<span class="iucrlogo">IUCr</span>');
 $(this).html(iucr_text);
});




